@{
    ViewData["Title"] = "Chronicles of Cebu";
}

<!-- HERO SECTION -->
<section class="py-16 text-center">
    <div class="max-w-3xl mx-auto px-6">
        <h1 class="title-font text-6xl font-semibold text-[#5b4632] mb-5">
            Chronicles of Cebu
        </h1>

        <p class="text-[#7b6f5f] leading-8 text-[15px]">
            Trace the indelible marks of time. Explore the pivotal eras that shaped
            the rich cultural tapestry and architectural heritage of the Queen City
            of the South.
        </p>
    </div>
</section>

<!-- TIMELINE SECTION -->
<section class="relative max-w-6xl mx-auto px-6 pb-28">

    <!-- VERTICAL CENTER LINE -->
    <div class="absolute left-1/2 top-0 h-full w-[1px] bg-[#cfc5af] transform -translate-x-1/2"></div>

    <!-- ERA 1: PRE-COLONIAL -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center mb-28 relative">

        <!-- CONTENT LEFT -->
        <div class="text-right pr-10">
            <p class="uppercase tracking-[4px] text-[11px] text-[#9a8f7c] mb-3">
                Before 1521
            </p>
            <h2 class="title-font text-4xl font-semibold mb-4 text-[#5b4632]">
                Pre-Colonial Roots
            </h2>
            <p class="leading-8 text-[#746957] text-[15px]">
                Long before western contact, Cebu was a thriving, deeply connected
                trading port known as Sugbu. A rich society governed by complex
                alliances and animated by vibrant indigenous traditions flourished
                along these coasts.
            </p>
        </div>

        <!-- IMAGE RIGHT -->
        <div class="pl-10">
            <img src="https://images.unsplash.com/photo-1518509562904-e7ef99cdcc86?q=80&w=1200&auto=format&fit=crop"
                 alt="Indigenous Art"
                 class="w-full max-w-md h-[250px] object-cover shadow-lg border border-[#d1c7b3] sepia-[.2]" />
        </div>

        <!-- DOT INDICATOR -->
        <div class="hidden md:block absolute left-1/2 top-1/2 w-3 h-3 bg-[#8b7355] rounded-full border-4 border-[#e8e4d3] transform -translate-x-1/2 -translate-y-1/2"></div>
    </div>

    <!-- ERA 2: SPANISH OCCUPATION -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center mb-28 relative">

        <!-- IMAGE LEFT -->
        <div class="pr-10 flex justify-end">
            <img src="https://images.unsplash.com/photo-1524492412937-b28074a5d7da?q=80&w=1200&auto=format&fit=crop"
                 alt="Stone Architecture"
                 class="w-full max-w-md h-[250px] object-cover shadow-lg border border-[#d1c7b3] sepia-[.2]" />
        </div>

        <!-- CONTENT RIGHT -->
        <div class="pl-10">
            <p class="uppercase tracking-[4px] text-[11px] text-[#9a8f7c] mb-3">
                1565 - 1898
            </p>
            <h2 class="title-font text-4xl font-semibold mb-4 text-[#5b4632]">
                Spanish Occupation
            </h2>
            <p class="leading-8 text-[#746957] text-[15px]">
                The arrival of Legazpi marked the beginning of over three centuries
                of Spanish rule. Christianity was deeply rooted, and massive
                coral-stone churches rose, forever altering the architectural and
                spiritual landscape of the island.
            </p>
        </div>

        <!-- DOT INDICATOR -->
        <div class="hidden md:block absolute left-1/2 top-1/2 w-3 h-3 bg-[#8b7355] rounded-full border-4 border-[#e8e4d3] transform -translate-x-1/2 -translate-y-1/2"></div>
    </div>

    <!-- ERA 3: AMERICAN PERIOD -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center relative">

        <!-- CONTENT LEFT -->
        <div class="text-right pr-10">
            <p class="uppercase tracking-[4px] text-[11px] text-[#9a8f7c] mb-3">
                1898 - 1946
            </p>
            <h2 class="title-font text-4xl font-semibold mb-4 text-[#5b4632]">
                The American Period
            </h2>
            <p class="leading-8 text-[#746957] text-[15px]">
                A rapid yet transformative modernization swept across Cebu:
                public education, new municipal infrastructure, and neoclassical
                civic buildings emerged. The port expanded, and Cebu evolved into
                a bustling center of commerce under American administration.
            </p>
        </div>

        <!-- IMAGE RIGHT -->
        <div class="pl-10">
            <img src="https://images.unsplash.com/photo-1514565131-fce0801e5785?q=80&w=1200&auto=format&fit=crop"
                 alt="Neoclassical Architecture"
                 class="w-full max-w-md h-[250px] object-cover shadow-lg border border-[#d1c7b3] sepia-[.2]" />
        </div>

        <!-- DOT INDICATOR -->
        <div class="hidden md:block absolute left-1/2 top-1/2 w-3 h-3 bg-[#8b7355] rounded-full border-4 border-[#e8e4d3] transform -translate-x-1/2 -translate-y-1/2"></div>
    </div>

</section>

<!-- OPTIONAL: CALL TO ACTION -->
<section class="max-w-4xl mx-auto px-6 py-20 text-center border-t border-[#cfc5af]">
    <h3 class="title-font text-3xl text-[#5b4632]">The Journey Continues</h3>
    <p class="mt-4 text-[#7b6f5f]">Our archive is updated as more records are digitized. Check back soon for the Post-War and Contemporary eras.</p>
</section>