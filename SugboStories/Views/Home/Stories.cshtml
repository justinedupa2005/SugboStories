@{
    ViewData["Title"] = "Stories";
}

<!-- HERO -->
<section class="max-w-7xl mx-auto px-10 py-14">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

        <!-- LEFT -->
        <div>
            <h1 class="title-font text-6xl leading-tight font-semibold text-[#644f3f]">
                Voices of the Queen City
            </h1>
            <p class="mt-8 text-[#7a6a5b] leading-relaxed text-lg max-w-xl">
                Journey through the layered history of Cebu. From the pre-colonial
                trading ports to the resilience shown during wartime, explore the
                narratives that shaped the cultural heart of the Visayas.
            </p>
        </div>

        <!-- RIGHT IMAGE -->
        <div>
            <img src="https://images.unsplash.com/photo-1518544866330-4e6f2b7f0b6d?q=80&w=1974&auto=format&fit=crop"
                 alt="Historic Cebu"
                 class="w-full h-[360px] object-cover rounded-sm shadow-lg sepia" />
        </div>

    </div>
</section>

<!-- FILTERS -->
<section class="max-w-7xl mx-auto px-10">
    <div class="flex flex-wrap gap-8 border-b border-[#d9d0bf] pb-5 text-sm font-medium text-[#7a6b5b]">
        <button class="hover:text-black transition">All Eras</button>
        <button class="hover:text-black transition">Pre-Colonial</button>
        <button class="hover:text-black transition">Spanish Era</button>
        <button class="hover:text-black transition">American Period</button>
        <button class="hover:text-black transition">WWII & Liberation</button>
        <button class="hover:text-black transition">Modern History</button>
    </div>
</section>

<!-- STORIES GRID -->
<section class="max-w-7xl mx-auto px-10 py-14">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">

        <!-- CARD 1 -->
        <div class="bg-[#faf8f1] border border-[#e1d8c8] shadow-sm overflow-hidden">
            <div class="relative">
                <img src="https://images.unsplash.com/photo-1511818966892-d7d671e672a2?q=80&w=1974&auto=format&fit=crop"
                     class="w-full h-72 object-cover sepia"
                     alt="Sugbu" />
                <span class="absolute top-4 left-4 bg-[#ece2d2] text-[#6a5747] text-xs px-4 py-1 rounded-full">
                    Spanish Era
                </span>
            </div>
            <div class="p-6">
                <h2 class="title-font text-4xl text-[#624e3e] leading-tight">
                    The Arrival at Sugbu
                </h2>
                <p class="mt-4 text-[#7c6c5c] text-sm leading-relaxed">
                    Tracing the momentous encounter between Rajah Humabon and
                    Ferdinand Magellan in 1521, an event that changed Cebu forever.
                </p>
                <button class="mt-6 border border-[#cbbba8] px-5 py-2 text-sm text-[#6a5747] hover:bg-[#ece2d2] transition">
                    Read More →
                </button>
            </div>
        </div>

        <!-- CARD 2 -->
        <div class="bg-[#faf8f1] border border-[#e1d8c8] shadow-sm overflow-hidden">
            <div class="relative">
                <img src="https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?q=80&w=1974&auto=format&fit=crop"
                     class="w-full h-72 object-cover sepia"
                     alt="Port" />
                <span class="absolute top-4 left-4 bg-[#ece2d2] text-[#6a5747] text-xs px-4 py-1 rounded-full">
                    American Period
                </span>
            </div>
            <div class="p-6">
                <h2 class="title-font text-4xl text-[#624e3e] leading-tight">
                    The Port of the South
                </h2>
                <p class="mt-4 text-[#7c6c5c] text-sm leading-relaxed">
                    How the development of the Cebu port during the early 1900s
                    transformed the city into the commercial hub of the Visayas.
                </p>
                <button class="mt-6 border border-[#cbbba8] px-5 py-2 text-sm text-[#6a5747] hover:bg-[#ece2d2] transition">
                    Read More →
                </button>
            </div>
        </div>

        <!-- CARD 3 -->
        <div class="bg-[#faf8f1] border border-[#e1d8c8] shadow-sm overflow-hidden">
            <div class="relative">
                <img src="https://images.unsplash.com/photo-1501594907352-04cda38ebc29?q=80&w=1974&auto=format&fit=crop"
                     class="w-full h-72 object-cover sepia"
                     alt="WWII" />
                <span class="absolute top-4 left-4 bg-[#ece2d2] text-[#6a5747] text-xs px-4 py-1 rounded-full">
                    WWII & Liberation
                </span>
            </div>
            <div class="p-6">
                <h2 class="title-font text-4xl text-[#624e3e] leading-tight">
                    Ashes and Resilience
                </h2>
                <p class="mt-4 text-[#7c6c5c] text-sm leading-relaxed">
                    A poignant look at the devastation of Cebu City during World War II
                    and the unwavering spirit of its people in rebuilding afterward.
                </p>
                <button class="mt-6 border border-[#cbbba8] px-5 py-2 text-sm text-[#6a5747] hover:bg-[#ece2d2] transition">
                    Read More →
                </button>
            </div>
        </div>

    </div>
</section>