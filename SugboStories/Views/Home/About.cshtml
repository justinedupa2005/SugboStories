@{
    ViewData["Title"] = "About";
}

<!-- HERO SECTION -->
<section class="max-w-7xl mx-auto px-10 py-20">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">

        <!-- LEFT CONTENT -->
        <div>
            <h1 class="title-font text-6xl font-semibold leading-tight text-[#5f4d3d]">
                Preserving the Soul of Cebu.
            </h1>

            <p class="mt-8 text-[#7a6a5a] leading-relaxed max-w-xl">
                The Cebu Living Archive is a digital sanctuary dedicated to
                documenting the rich history, culture, and artistic identity of Cebu
                City and the Visayas. We bridge the gap between historical memory
                and modern accessibility.
            </p>
        </div>

        <!-- RIGHT IMAGE -->
        <div class="flex justify-center lg:justify-end">
            <img src="https://images.unsplash.com/photo-1566552881560-0be862a7c445?q=80&w=1974&auto=format&fit=crop"
                 alt="Historic Church"
                 class="w-full max-w-md h-[420px] object-cover shadow-lg sepia" />
        </div>

    </div>
</section>

<!-- MISSION STATEMENT -->
<section class="max-w-5xl mx-auto px-10">
    <div class="border border-[#d8ccb9] bg-[#f7f4eb] text-center px-10 py-16 shadow-sm">

        <!-- Icon -->
        <div class="flex justify-center">
            <div class="w-12 h-12 rounded-full border border-[#cbbca9] flex items-center justify-center text-[#7d6b5b] text-xl">
                ⛩
            </div>
        </div>

        <h2 class="title-font text-4xl mt-6 text-[#5f4d3d]">
            Our Mission
        </h2>

        <p class="mt-6 text-[#786859] leading-relaxed max-w-3xl mx-auto">
            To digitize, curate, and protect the artifacts, oral histories,
            and architectural heritage of Cebu. We believe that history is not static;
            it is a living narrative that must be continuously engaged with to
            inform our future. We are building a bridge across centuries.
        </p>

    </div>
</section>

<!-- COLLECTION CATEGORIES -->
<section class="max-w-7xl mx-auto px-10 py-24">

    <!-- Heading -->
    <div class="mb-12">
        <h2 class="title-font text-5xl text-[#5f4d3d]">
            The Collection
        </h2>
        <p class="mt-3 text-[#7c6c5c]">
            A continuously expanding archive of our digital heritage.
        </p>
    </div>

    <!-- GRID -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        <!-- LARGE CARD: ARTIFACTS -->
        <div class="relative overflow-hidden bg-[#eee7d9] h-[260px] group">
            <img src="https://images.unsplash.com/photo-1517842645767-c639042777db?q=80&w=1974&auto=format&fit=crop"
                 alt="Documents"
                 class="w-full h-full object-cover sepia group-hover:scale-105 transition duration-500" />
            <div class="absolute inset-0 bg-black/20"></div>
            <div class="absolute bottom-0 left-0 p-8 text-white">
                <h3 class="title-font text-4xl">
                    Artifacts & Documents
                </h3>
                <p class="mt-2 text-sm text-[#f1ece4]">
                    Rare manuscripts, ledgers, letters, and preserved records.
                </p>
            </div>
        </div>

        <!-- SMALL CARD: ORAL HISTORIES -->
        <div class="bg-[#f8f5ed] border border-[#ddd2c2] flex flex-col justify-center items-center text-center p-10">
            <div class="text-4xl text-[#7c6b5b]">🎙</div>
            <h3 class="title-font text-3xl mt-5 text-[#5f4d3d]">
                Oral Histories
            </h3>
            <p class="mt-4 text-[#7c6c5c] text-sm leading-relaxed">
                Audio recordings from local elders and cultural bearers.
            </p>
        </div>

        <!-- SMALL CARD: CARTOGRAPHY -->
        <div class="bg-[#f8f5ed] border border-[#ddd2c2] flex flex-col justify-center items-center text-center p-10">
            <div class="text-4xl text-[#7c6b5b]">🗺</div>
            <h3 class="title-font text-3xl mt-5 text-[#5f4d3d]">
                Cartography
            </h3>
            <p class="mt-4 text-[#7c6c5c] text-sm leading-relaxed">
                Historical maps tracing the evolution of the city layout.
            </p>
        </div>

        <!-- LARGE CARD: ARCHITECTURE -->
        <div class="relative overflow-hidden bg-[#eee7d9] h-[260px] group">
            <img src="https://images.unsplash.com/photo-1506744038136-46273834b3fb?q=80&w=1974&auto=format&fit=crop"
                 alt="Architecture"
                 class="w-full h-full object-cover sepia group-hover:scale-105 transition duration-500" />
            <div class="absolute inset-0 bg-black/30"></div>
            <div class="absolute bottom-0 left-0 p-8 text-white">
                <h3 class="title-font text-4xl">
                    Architectural Heritage
                </h3>
                <p class="mt-2 text-sm text-[#f1ece4]">
                    Churches and heritage structures preserved through generations.
                </p>
            </div>
        </div>

    </div>
</section>